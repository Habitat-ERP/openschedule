{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/za-sars/customs-source.v1",
  "title": "SARS Customs Source V1",
  "description": "Official SARS customs source document reference discovered for local user fetch.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "country",
    "publisher",
    "domain",
    "family",
    "documentRole",
    "schedule",
    "title",
    "sourceFormat",
    "registryPageUrl",
    "sourceUrl"
  ],
  "properties": {
    "schemaVersion": {
      "const": "za-sars.customs-source.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^ZA_SARS_CUSTOMS_[A-Z0-9_]+$"
    },
    "country": {
      "const": "ZA"
    },
    "publisher": {
      "const": "SARS"
    },
    "domain": {
      "const": "za-customs"
    },
    "family": {
      "enum": [
        "schedule-1-customs",
        "schedule-1-excise-levies",
        "schedule-2-trade-remedies",
        "rebates-drawbacks-refunds",
        "amendment-notices"
      ]
    },
    "documentRole": {
      "enum": [
        "consolidated-schedule",
        "amendment-registry"
      ]
    },
    "schedule": {
      "enum": [
        "1",
        "2",
        "3",
        "4",
        "5",
        "6",
        null
      ]
    },
    "part": {
      "type": "string",
      "minLength": 1
    },
    "section": {
      "type": "string",
      "minLength": 1
    },
    "chapterRange": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sourceFormat": {
      "enum": [
        "application/pdf",
        "text/html"
      ]
    },
    "sourceUpdatedDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "registryPageUrl": {
      "type": "string",
      "format": "uri"
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri"
    }
  }
}
