{
  "name": "@openschedule/za-sars",
  "version": "0.1.0",
  "description": "Official SARS customs source discovery, status checks, and local fetch helpers for OpenSchedule.",
  "keywords": [
    "south africa revenue service customs",
    "sars customs source discovery",
    "customs schedule pdf fetch",
    "tariff source status check",
    "local customs source cache",
    "source document provenance",
    "south africa customs data"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/za-sars"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openschedule/core": "0.1.0"
  }
}
