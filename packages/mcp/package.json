{
  "name": "@openschedule/mcp",
  "version": "0.1.2",
  "mcpName": "io.github.habitat-erp/openschedule",
  "description": "MCP server exposing OpenSchedule ZA customs lookup, source trace, schemas, and mechanical duty estimate tools.",
  "keywords": [
    "openschedule mcp",
    "mcp server customs tariff",
    "model context protocol customs",
    "ai agent customs tools",
    "south africa sars customs mcp",
    "za customs mcp server",
    "tariff lookup mcp tool",
    "customs source trace tool"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "bin": {
    "openschedule-mcp": "./dist/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "server.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openschedule/core": "0.1.1",
    "@openschedule/za-customs": "0.1.2",
    "@openschedule/za-sars": "0.1.1"
  }
}
