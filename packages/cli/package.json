{
  "name": "@openschedule/cli",
  "version": "0.1.2",
  "description": "CLI for OpenSchedule ZA customs sync, tariff lookup, source trace, and mechanical duty estimates.",
  "keywords": [
    "openschedule cli",
    "south african customs cli",
    "sars customs schedule cli",
    "za customs sync command",
    "tariff lookup command line",
    "mechanical duty estimate cli",
    "customs source trace cli",
    "local customs cache cli"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "bin": {
    "openschedule": "./dist/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openschedule/core": "0.1.1",
    "@openschedule/za-customs": "0.1.2",
    "@openschedule/za-sars": "0.1.1"
  }
}
