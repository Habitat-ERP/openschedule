{
  "name": "@openschedule/cli",
  "version": "0.1.0",
  "description": "Command-line tools for OpenSchedule statutory rulesets.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "bin": {
    "openschedule": "./dist/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openschedule/core": "0.1.0",
    "@openschedule/za-customs": "0.1.0",
    "@openschedule/za-sars": "0.1.0"
  }
}
