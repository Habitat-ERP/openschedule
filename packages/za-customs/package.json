{
  "name": "@openschedule/za-customs",
  "version": "0.1.2",
  "description": "Local-cache TypeScript API for South African SARS customs schedule lookup, source trace, and mechanical duty estimates.",
  "keywords": [
    "south african customs tariff lookup",
    "sars customs schedules",
    "south africa import duty estimate",
    "mechanical customs duty estimate",
    "hs tariff rate lookup",
    "local customs ruleset cache",
    "customs source provenance",
    "rebates drawbacks refunds"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/za-customs"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./internal": {
      "types": "./dist/src/internal.d.ts",
      "import": "./dist/src/internal.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openschedule/core": "0.1.1",
    "@openschedule/za-sars": "0.1.1",
    "pdfjs-dist": "^6.1.200"
  }
}
