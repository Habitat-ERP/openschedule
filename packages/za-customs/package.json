{
  "name": "@openschedule/za-customs",
  "version": "0.1.0",
  "description": "Consumer API and ruleset tooling for South African customs schedules.",
  "keywords": [
    "south-africa",
    "customs",
    "sars",
    "tariff",
    "hs-code",
    "customs-duty",
    "ruleset",
    "provenance"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/za-customs"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./internal": {
      "types": "./dist/src/internal.d.ts",
      "import": "./dist/src/internal.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openschedule/core": "0.1.0",
    "@openschedule/za-sars": "0.1.0",
    "pdfjs-dist": "^6.1.200"
  }
}
