{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/za-customs/schedule5-parse-result.v1",
  "title": "Schedule 5 Parse Result V1",
  "description": "Parser result for SARS Schedule 5 drawback and refund lines, including quality metrics and source provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "drawbackRefundLines",
    "warnings",
    "metrics"
  ],
  "properties": {
    "schemaVersion": {
      "const": "za-customs.schedule5-parse-result.v1"
    },
    "drawbackRefundLines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/drawbackRefundLine"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "pageMetrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pageMetrics"
      }
    }
  },
  "$defs": {
    "part": {
      "enum": [
        "1",
        "2",
        "3",
        "4",
        "5",
        "6",
        "unknown"
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pagesParsed",
        "textItems",
        "layoutRows",
        "candidateRows",
        "contextRows",
        "drawbackRefundLines",
        "rejectedRows"
      ],
      "properties": {
        "pagesParsed": {
          "type": "integer",
          "minimum": 0
        },
        "textItems": {
          "type": "integer",
          "minimum": 0
        },
        "layoutRows": {
          "type": "integer",
          "minimum": 0
        },
        "candidateRows": {
          "type": "integer",
          "minimum": 0
        },
        "contextRows": {
          "type": "integer",
          "minimum": 0
        },
        "drawbackRefundLines": {
          "type": "integer",
          "minimum": 0
        },
        "rejectedRows": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "pageMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pageNumber",
        "textItems",
        "layoutRows",
        "candidateRows",
        "contextRows",
        "drawbackRefundLines",
        "rejectedRows"
      ],
      "properties": {
        "pageNumber": {
          "type": "integer",
          "minimum": 1
        },
        "textItems": {
          "type": "integer",
          "minimum": 0
        },
        "layoutRows": {
          "type": "integer",
          "minimum": 0
        },
        "candidateRows": {
          "type": "integer",
          "minimum": 0
        },
        "contextRows": {
          "type": "integer",
          "minimum": 0
        },
        "drawbackRefundLines": {
          "type": "integer",
          "minimum": 0
        },
        "rejectedRows": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "drawbackRefundContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part",
        "item",
        "normalizedItem",
        "description",
        "normalizedDescription",
        "level",
        "sourceTrace"
      ],
      "properties": {
        "part": {
          "$ref": "#/$defs/part"
        },
        "item": {
          "type": "string",
          "minLength": 1
        },
        "normalizedItem": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        }
      }
    },
    "drawbackRefundLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "part",
        "item",
        "normalizedItem",
        "tariffHeading",
        "normalizedTariffHeading",
        "code",
        "normalizedCode",
        "description",
        "normalizedDescription",
        "extentOfRefundOrDrawback",
        "validFrom",
        "sourceTrace",
        "parseConfidence",
        "warnings"
      ],
      "properties": {
        "schemaVersion": {
          "const": "za-customs.schedule5-drawback-refund-line.v1"
        },
        "part": {
          "$ref": "#/$defs/part"
        },
        "item": {
          "type": "string",
          "minLength": 1
        },
        "normalizedItem": {
          "type": "string",
          "minLength": 1
        },
        "tariffHeading": {
          "type": "string",
          "minLength": 1
        },
        "normalizedTariffHeading": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "normalizedCode": {
          "type": "string",
          "minLength": 1
        },
        "checkDigit": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "extentOfRefundOrDrawback": {
          "type": "string"
        },
        "validFrom": {
          "type": "string"
        },
        "context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/drawbackRefundContext"
          }
        },
        "sourcePublishedDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceImplementationDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        },
        "parseConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
