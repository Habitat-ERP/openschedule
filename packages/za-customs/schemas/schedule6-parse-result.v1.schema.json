{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/za-customs/schedule6-parse-result.v1",
  "title": "Schedule 6 Parse Result V1",
  "description": "Parser result for SARS Schedule 6 excise rebate and refund lines, including quality metrics and source provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "exciseRebateRefundLines",
    "warnings",
    "metrics"
  ],
  "properties": {
    "schemaVersion": {
      "const": "za-customs.schedule6-parse-result.v1"
    },
    "exciseRebateRefundLines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exciseRebateRefundLine"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "pageMetrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pageMetrics"
      }
    }
  },
  "$defs": {
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pagesParsed",
        "textItems",
        "layoutRows",
        "candidateRows",
        "contextRows",
        "exciseRebateRefundLines",
        "rejectedRows"
      ],
      "properties": {
        "pagesParsed": {
          "type": "integer",
          "minimum": 0
        },
        "textItems": {
          "type": "integer",
          "minimum": 0
        },
        "layoutRows": {
          "type": "integer",
          "minimum": 0
        },
        "candidateRows": {
          "type": "integer",
          "minimum": 0
        },
        "contextRows": {
          "type": "integer",
          "minimum": 0
        },
        "exciseRebateRefundLines": {
          "type": "integer",
          "minimum": 0
        },
        "rejectedRows": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "pageMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pageNumber",
        "textItems",
        "layoutRows",
        "candidateRows",
        "contextRows",
        "exciseRebateRefundLines",
        "rejectedRows"
      ],
      "properties": {
        "pageNumber": {
          "type": "integer",
          "minimum": 1
        },
        "textItems": {
          "type": "integer",
          "minimum": 0
        },
        "layoutRows": {
          "type": "integer",
          "minimum": 0
        },
        "candidateRows": {
          "type": "integer",
          "minimum": 0
        },
        "contextRows": {
          "type": "integer",
          "minimum": 0
        },
        "exciseRebateRefundLines": {
          "type": "integer",
          "minimum": 0
        },
        "rejectedRows": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "exciseRebateRefundContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part",
        "item",
        "normalizedItem",
        "description",
        "normalizedDescription",
        "level",
        "sourceTrace"
      ],
      "properties": {
        "part": {
          "type": "string",
          "minLength": 1
        },
        "item": {
          "type": "string",
          "minLength": 1
        },
        "normalizedItem": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        }
      }
    },
    "exciseRebateRefundLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "part",
        "item",
        "normalizedItem",
        "tariffItem",
        "normalizedTariffItem",
        "rebateCode",
        "normalizedRebateCode",
        "description",
        "normalizedDescription",
        "extentOfRebate",
        "extentOfRefund",
        "validFrom",
        "sourceTrace",
        "parseConfidence",
        "warnings"
      ],
      "properties": {
        "schemaVersion": {
          "const": "za-customs.schedule6-excise-rebate-refund-line.v1"
        },
        "part": {
          "type": "string",
          "minLength": 1
        },
        "item": {
          "type": "string",
          "minLength": 1
        },
        "normalizedItem": {
          "type": "string",
          "minLength": 1
        },
        "tariffItem": {
          "type": "string",
          "minLength": 1
        },
        "normalizedTariffItem": {
          "type": "string",
          "minLength": 1
        },
        "rebateCode": {
          "type": "string",
          "minLength": 1
        },
        "normalizedRebateCode": {
          "type": "string",
          "minLength": 1
        },
        "checkDigit": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "extentOfRebate": {
          "type": "string"
        },
        "extentOfRefund": {
          "type": "string"
        },
        "validFrom": {
          "type": "string"
        },
        "context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/exciseRebateRefundContext"
          }
        },
        "sourcePublishedDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceImplementationDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        },
        "parseConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
