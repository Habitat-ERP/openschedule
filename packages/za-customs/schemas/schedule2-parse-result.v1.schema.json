{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/za-customs/schedule2-parse-result.v1",
  "title": "Schedule 2 Parse Result V1",
  "description": "Parser result for SARS Schedule 2 trade remedy duties, including quality metrics and source provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tradeRemedyLines",
    "warnings",
    "metrics"
  ],
  "properties": {
    "schemaVersion": {
      "const": "za-customs.schedule2-parse-result.v1"
    },
    "tradeRemedyLines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tradeRemedyLine"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "pageMetrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pageMetrics"
      }
    }
  },
  "$defs": {
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pagesParsed",
        "textItems",
        "layoutRows",
        "candidateRows",
        "contextRows",
        "tradeRemedyLines",
        "rejectedRows"
      ],
      "properties": {
        "pagesParsed": {
          "type": "integer",
          "minimum": 0
        },
        "textItems": {
          "type": "integer",
          "minimum": 0
        },
        "layoutRows": {
          "type": "integer",
          "minimum": 0
        },
        "candidateRows": {
          "type": "integer",
          "minimum": 0
        },
        "contextRows": {
          "type": "integer",
          "minimum": 0
        },
        "tradeRemedyLines": {
          "type": "integer",
          "minimum": 0
        },
        "rejectedRows": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "pageMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pageNumber",
        "textItems",
        "layoutRows",
        "candidateRows",
        "contextRows",
        "tradeRemedyLines",
        "rejectedRows"
      ],
      "properties": {
        "pageNumber": {
          "type": "integer",
          "minimum": 1
        },
        "textItems": {
          "type": "integer",
          "minimum": 0
        },
        "layoutRows": {
          "type": "integer",
          "minimum": 0
        },
        "candidateRows": {
          "type": "integer",
          "minimum": 0
        },
        "contextRows": {
          "type": "integer",
          "minimum": 0
        },
        "tradeRemedyLines": {
          "type": "integer",
          "minimum": 0
        },
        "rejectedRows": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tradeRemedyContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "normalizedItem",
        "description",
        "normalizedDescription",
        "level",
        "sourceTrace"
      ],
      "properties": {
        "item": {
          "type": "string",
          "minLength": 1
        },
        "normalizedItem": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        }
      }
    },
    "tradeRemedyLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "item",
        "normalizedItem",
        "tariffHeading",
        "normalizedTariffHeading",
        "code",
        "normalizedCode",
        "description",
        "normalizedDescription",
        "rebateItems",
        "originatingCountryOrTerritory",
        "rate",
        "validFrom",
        "sourceTrace",
        "parseConfidence",
        "warnings"
      ],
      "properties": {
        "schemaVersion": {
          "const": "za-customs.schedule2-trade-remedy-line.v1"
        },
        "item": {
          "type": "string",
          "minLength": 1
        },
        "normalizedItem": {
          "type": "string",
          "minLength": 1
        },
        "tariffHeading": {
          "type": "string",
          "minLength": 1
        },
        "normalizedTariffHeading": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "normalizedCode": {
          "type": "string",
          "minLength": 1
        },
        "checkDigit": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "rebateItems": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "originatingCountryOrTerritory": {
          "type": "string"
        },
        "rate": {
          "$ref": "#/$defs/dutyRate"
        },
        "validFrom": {
          "type": "string"
        },
        "context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tradeRemedyContext"
          }
        },
        "sourcePublishedDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceImplementationDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        },
        "parseConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dutyRate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw",
        "kind",
        "components",
        "warnings"
      ],
      "properties": {
        "raw": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "free",
            "ad_valorem",
            "specific",
            "compound",
            "formula",
            "unknown"
          ]
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dutyRateComponent"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dutyRateComponent": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "basis",
            "rate"
          ],
          "properties": {
            "basis": {
              "const": "customs_value"
            },
            "rate": {
              "type": "number"
            },
            "qualifier": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amount",
            "currency",
            "perQuantity",
            "unit"
          ],
          "properties": {
            "amount": {
              "type": "number"
            },
            "currency": {
              "enum": [
                "ZAR",
                "ZAc"
              ]
            },
            "perQuantity": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "unit": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "basis",
            "qualifier"
          ],
          "properties": {
            "basis": {
              "const": "qualified_free"
            },
            "qualifier": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
