{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/za-customs/tariff-line.v1",
  "title": "Tariff Line V1",
  "description": "A parsed SARS customs tariff line preserving raw official text, parsed rates, and source provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tariffCode",
    "normalizedTariffCode",
    "description",
    "normalizedDescription",
    "rates",
    "validFrom",
    "sourceTrace",
    "parseConfidence",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "za-customs.tariff-line.v1"
    },
    "tariffCode": {
      "type": "string",
      "minLength": 1
    },
    "normalizedTariffCode": {
      "type": "string",
      "minLength": 1
    },
    "checkDigit": {
      "type": [
        "string",
        "null"
      ]
    },
    "description": {
      "type": "string"
    },
    "normalizedDescription": {
      "type": "string"
    },
    "statisticalUnit": {
      "type": [
        "string",
        "null"
      ]
    },
    "context": {
      "type": "array",
      "description": "Active heading/subheading hierarchy rows that provide context for this tariff line.",
      "items": {
        "$ref": "#/$defs/tariffLineContext"
      }
    },
    "rates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "general"
      ],
      "properties": {
        "general": {
          "$ref": "#/$defs/dutyRate"
        },
        "euUk": {
          "$ref": "#/$defs/dutyRate"
        },
        "efta": {
          "$ref": "#/$defs/dutyRate"
        },
        "sadc": {
          "$ref": "#/$defs/dutyRate"
        },
        "mercosur": {
          "$ref": "#/$defs/dutyRate"
        },
        "afcfta": {
          "$ref": "#/$defs/dutyRate"
        }
      }
    },
    "validFrom": {
      "type": "string"
    },
    "validTo": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourcePublishedDate": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceImplementationDate": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceTrace": {
      "type": "array",
      "items": {
        "$ref": "openschedule://schemas/core/source-trace.v1"
      }
    },
    "parseConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "tariffLineContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "normalizedCode",
        "description",
        "normalizedDescription",
        "level",
        "sourceTrace"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "normalizedCode": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "normalizedDescription": {
          "type": "string"
        },
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "sourceTrace": {
          "type": "array",
          "items": {
            "$ref": "openschedule://schemas/core/source-trace.v1"
          }
        }
      }
    },
    "dutyRate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw",
        "kind",
        "components",
        "warnings"
      ],
      "properties": {
        "raw": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "free",
            "ad_valorem",
            "specific",
            "compound",
            "formula",
            "unknown"
          ]
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dutyRateComponent"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dutyRateComponent": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "basis",
            "rate"
          ],
          "properties": {
            "basis": {
              "const": "customs_value"
            },
            "rate": {
              "type": "number"
            },
            "qualifier": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amount",
            "currency",
            "perQuantity",
            "unit"
          ],
          "properties": {
            "amount": {
              "type": "number"
            },
            "currency": {
              "enum": [
                "ZAR",
                "ZAc"
              ]
            },
            "perQuantity": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "unit": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "basis",
            "qualifier"
          ],
          "properties": {
            "basis": {
              "const": "qualified_free"
            },
            "qualifier": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
