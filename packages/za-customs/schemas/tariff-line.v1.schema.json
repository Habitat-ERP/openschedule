{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/za-customs/tariff-line.v1",
  "title": "Tariff Line V1",
  "description": "A parsed SARS customs tariff line preserving raw official text, parsed rates, and source provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tariffCode",
    "normalizedTariffCode",
    "description",
    "rates",
    "validFrom",
    "sourceTrace",
    "parseConfidence",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "za-customs.tariff-line.v1"
    },
    "tariffCode": {
      "type": "string",
      "minLength": 1
    },
    "normalizedTariffCode": {
      "type": "string",
      "minLength": 1
    },
    "checkDigit": {
      "type": [
        "string",
        "null"
      ]
    },
    "description": {
      "type": "string"
    },
    "statisticalUnit": {
      "type": [
        "string",
        "null"
      ]
    },
    "rates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "general"
      ],
      "properties": {
        "general": {
          "$ref": "#/$defs/dutyRate"
        },
        "euUk": {
          "$ref": "#/$defs/dutyRate"
        },
        "efta": {
          "$ref": "#/$defs/dutyRate"
        },
        "sadc": {
          "$ref": "#/$defs/dutyRate"
        },
        "mercosur": {
          "$ref": "#/$defs/dutyRate"
        },
        "afcfta": {
          "$ref": "#/$defs/dutyRate"
        }
      }
    },
    "validFrom": {
      "type": "string"
    },
    "validTo": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourcePublishedDate": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceImplementationDate": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceTrace": {
      "type": "array",
      "items": {
        "$ref": "openschedule://schemas/core/source-trace.v1"
      }
    },
    "parseConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "dutyRate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw",
        "kind",
        "components",
        "warnings"
      ],
      "properties": {
        "raw": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "free",
            "ad_valorem",
            "specific",
            "compound",
            "formula",
            "unknown"
          ]
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
