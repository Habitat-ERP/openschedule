{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/core/source-document-metadata.v1",
  "title": "Source Document Metadata V1",
  "description": "Metadata for an official source document processed in a user's environment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sha256"
  ],
  "properties": {
    "schemaVersion": {
      "const": "core.source-document-metadata.v1"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "fileName": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceUrl": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceIdentifier": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Publisher or registry identifier for the source document, when known."
    },
    "sourceRole": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Role of this source in a generated ruleset, such as a consolidated schedule or amendment registry."
    },
    "publishedDate": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "effectiveDate": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "supersededBy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "retrievedAt": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO 8601 timestamp for local retrieval, when known."
    }
  }
}
