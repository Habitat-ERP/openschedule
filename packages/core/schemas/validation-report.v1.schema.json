{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openschedule://schemas/core/validation-report.v1",
  "title": "Validation Report V1",
  "description": "A small validation result for generated OpenSchedule artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "valid",
    "issues"
  ],
  "properties": {
    "schemaVersion": {
      "const": "core.validation-report.v1"
    },
    "valid": {
      "type": "boolean"
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationIssue"
      }
    }
  },
  "$defs": {
    "validationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "severity",
        "code",
        "message"
      ],
      "properties": {
        "schemaVersion": {
          "const": "core.validation-issue.v1"
        },
        "severity": {
          "enum": [
            "error",
            "warning"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
