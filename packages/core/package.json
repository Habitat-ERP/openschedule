{
  "name": "@openschedule/core",
  "version": "0.1.1",
  "description": "Deterministic TypeScript types, JSON Schemas, source traces, validation reports, and diff contracts for OpenSchedule statutory rulesets.",
  "keywords": [
    "openschedule",
    "statutory ruleset schema",
    "auditable statutory data",
    "source trace metadata",
    "ruleset validation report",
    "deterministic json schema",
    "typescript legal data contracts"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Habitat-ERP/openschedule.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Habitat-ERP/openschedule#readme",
  "bugs": {
    "url": "https://github.com/Habitat-ERP/openschedule/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  }
}
